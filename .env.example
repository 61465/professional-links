# ── Backend ────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no spaces).
# Dev default if unset: http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,https://mobeface.pages.dev

# Cache TTL for /api/listings responses (seconds). 15 min default.
CACHE_TTL_SECONDS=900

# Logging level for the backend.
LOG_LEVEL=INFO

# ── Frontend (Vite — build-time only) ──────────────────────────────
# Leave empty in dev (vite proxies /api to :8001).
# In prod set to the public backend URL, e.g. https://mobeface-api.fly.dev
VITE_API_BASE=
